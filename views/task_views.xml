<odoo>

    <!-- Tree View -->
    <record id="view_task_tree" model="ir.ui.view">
        <field name="name">task.manager.tree</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="is_done"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_task_form" model="ir.ui.view">
        <field name="name">task.manager.form</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="is_done"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_task_manager" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">task.manager</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_task_root" name="Task Manager"/>
    <menuitem id="menu_task"
              name="Tasks"
              parent="menu_task_root"
              action="action_task_manager"/>

</odoo>